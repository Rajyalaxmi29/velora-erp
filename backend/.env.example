# ─── Velora ERP Backend ───────────────────────────
# Server
PORT=5000
NODE_ENV=development

# Database
DATABASE_URL="postgresql://postgres:password@localhost:5432/velora_erp?schema=public"

# JWT
JWT_SECRET=change-this-in-production
JWT_EXPIRES_IN=7d
JWT_REFRESH_EXPIRES_IN=30d

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:5174

# Logging
LOG_LEVEL=dev
